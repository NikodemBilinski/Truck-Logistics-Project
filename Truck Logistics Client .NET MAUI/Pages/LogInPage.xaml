<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrucksLogisticsClient.MainPage">


    <VerticalStackLayout>
        
        <Label Text="Welcome to Truck Logistics App"
               FontSize="24"
               HorizontalOptions="Center"
               Margin="0,20,0,20"/>
        
        <!--Error Border (FOOOOOOOOOOOOOR CRAZYYYYY ERRRRORRRSSSS)-->

        <Border x:Name="ErrorBorder"
                Stroke="Black"
                StrokeThickness="5"
                IsVisible="False"
                Margin="30"
                Padding="10"
                WidthRequest="300">
            <VerticalStackLayout>
                <Label x:Name="ErrorLabel"
                       TextColor="Red"
                       HorizontalOptions="Center"
                       Margin="0,10,0,10"/>

                <Button x:Name="ErrorButton"
                        Text="Close"
                        Clicked="Close_Error"
                        IsVisible="False"
                        IsEnabled="False"
                        WidthRequest="100"/>
            </VerticalStackLayout>
        </Border>
        
        <Entry x:Name="Login_entry"
               Placeholder="Enter your username"/>

        <Entry x:Name="Password_entry"
               Placeholder="Enter your password"/>
        
        <Label x:Name="LoginResultLabel"
               Text="Login result will be displayed here"/>
        
        <Button Text="Login"
                Clicked="Login_Clicked"/>
        

    </VerticalStackLayout>

</ContentPage>
