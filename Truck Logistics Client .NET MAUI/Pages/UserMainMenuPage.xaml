<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:TrucksLogisticsClient.Models"
             x:Class="TrucksLogisticsClient.Pages.UserMainMenuPage"
             x:DataType="model:Users"
             Shell.NavBarIsVisible="False">
    
    
    <Grid ColumnDefinitions="200, *">

        <VerticalStackLayout Grid.Column="1">
            <VerticalStackLayout HorizontalOptions="Center">

                <Label Text="{Binding Username, StringFormat='Welcome, {0}!'}"
                       FontSize="40"
                       HorizontalOptions="Center"
                       Margin="20"/>


                <Label x:Name="User_Error_Label_Main"
                       TextColor="Red"/>
        
            </VerticalStackLayout>
            
            <!--User Show Data-->
            <VerticalStackLayout x:Name="User_Show_Data_View" IsVisible="False" IsEnabled="False" HorizontalOptions="Center">
                <Label Text="ferfaefra"/>
                <Label Text="{Binding FirstName}"/>
                <Label Text="{Binding LastName}"/>
                <Label Text="{Binding Age}"/>
                <Label Text="{Binding Username}"/>
                <Label Text="{Binding Role}"/>
                <Label Text="{Binding AssignedTrucks.Count, StringFormat='Assigned Trucks: {0}'}"/>
                <Label Text="{Binding AssignedJobs.Count, StringFormat='Assigned Jobs: {0}'}"/>
                <Label Text="{Binding isBusy}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding isBusy}" Value="True">
                            <Setter Property="Text" Value="Avaiable"/>
                            <Setter Property="TextColor" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding isBusy}" Value="False">
                            <Setter Property="Text" Value="Busy"/>
                            <Setter Property="TextColor" Value="Red"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="test" IsEnabled="False" IsVisible="False">
                <CollectionView x:Name="kolekcja" WidthRequest="300" HeightRequest="300">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Truck">
                            <VerticalStackLayout>
                                <Label Text="fwerfgearfgeragergerg"/>
                                <Label Text="{Binding Name}"/>
                                <Label Text="{Binding brand}"/>
                                <Label Text="{Binding Capacity}"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
        
        
        
        <VerticalStackLayout Grid.Column="0" Margin="10" VerticalOptions="Center">
            <Border StrokeThickness="5"
                    StrokeShape="RoundRectangle 50"
                    Stroke="Beige"
                    Padding="50">
                <VerticalStackLayout Spacing="25">
                <Button Text="Show Data"
                        WidthRequest="125"
                        Clicked="User_Show_Data"/>
                <Button Text="Show Trucks"
                        WidthRequest="125"
                        Clicked="Tescik"/>
                <Button Text="Show Jobs"
                    WidthRequest="125"/>
                <Button Text="Edit Data"
                    WidthRequest="125"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>