<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:TrucksLogisticsClient.Models"
             x:Class="TrucksLogisticsClient.Pages.MainMenuPage"
             NavigationPage.HasNavigationBar="False">

    
    <Grid ColumnDefinitions="200,*"
          MinimumHeightRequest="1000">


        <VerticalStackLayout Grid.Column="1" Margin="10">

            <!--UserDataHeader-->
            <Border x:Name="UserDataHeader"
                    StrokeShape="RoundRectangle 20,20,20,20"
                    WidthRequest="250">

                <Label x:Name="Welcome_User_Label"
                       Text="{Binding FirstName , StringFormat='Welcome, {0}!'}"
                       FontSize="30"
                       HorizontalOptions="Center"
                       Margin="0,10,0,10"/>
            </Border>


            <!--UserDataMain-->
            <Border x:Name="UserDataMain"
                    x:DataType="model:Users"
                    StrokeShape="RoundRectangle 20,20,20,20"
                    WidthRequest="500"
                    Margin="20"
                    Padding="20">
                <VerticalStackLayout>
                    <Label Text="Profile Data:"
                           HorizontalOptions="Center"
                           FontSize="25"/>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding FirstName}"/>
                        <Label Text="{Binding LastName}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="Age: "/>
                        <Label Text="{Binding Age}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="Role: "/>
                        <Label Text="{Binding Role}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--Show Data-->

            <VerticalStackLayout Margin="20" Spacing="0">
                <Grid ColumnDefinitions="50,150,150,100,100,80,100,*" 
                      Margin="0,10,-60,0"
                      BackgroundColor="Transparent" 
                      Padding="10"
                      HorizontalOptions="Center">
                    <Label Grid.Column="0" Text="ID" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Full Name" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Username" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Role" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Status" FontAttributes="Bold"/>
                    <Label Grid.Column="5" Text="Age" FontAttributes="Bold"/>
                    <Label Grid.Column="6" Text="Trucks" FontAttributes="Bold"/>
                    <Label Grid.Column="7" Text="Languages" FontAttributes="Bold"/>
                </Grid>

                <CollectionView x:Name="Get_All_Users_View">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Users">
                            <Grid ColumnDefinitions="50,150,150,100,100,80,100,*" 
                                  Padding="10"
                                  HorizontalOptions="Center">
                                
                                <Label Grid.Column="0" Text="{Binding ID}"/>
                                <HorizontalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding FirstName}"/>
                                    <Label Text="{Binding LastName}"/>
                                </HorizontalStackLayout>

                                <Label Grid.Column="2" Text="{Binding Username}"/>
                                <Label Grid.Column="3" Text="{Binding Role}"/>
                                <Label Grid.Column="4" Text="{Binding isBusy}"/>
                                <Label Grid.Column="5" Text="{Binding Age}"/>
                                <Label Grid.Column="6" Text="{Binding AssignedTrucks.Count}"/>
                                <Label Grid.Column="7" Text="{Binding Languages.Count}"/>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Column="0" Margin="10">

            <!--DataPanel-->
            <Border StrokeThickness="5"
                    Stroke="Beige"
                    Padding="50">
                <VerticalStackLayout Spacing="25">
                   
                    <Button x:Name="User_Get_Trucks"
                            Text="Get Your Trucks"
                            IsEnabled="False"
                            IsVisible="False"
                            WidthRequest="125"/>

                    <Button x:Name="Admin_Get_Trucks"
                            Text="Get All Trucks"
                            IsEnabled="False"
                            IsVisible="False"
                            WidthRequest="125"/>

                    <Button x:Name="Admin_Get_Users"
                            Text="Get All Users"
                            Clicked="Admin_Get_Users_Clicked"
                            IsEnabled="False"
                            IsVisible="False"
                            WidthRequest="125"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>